# Localstack
LOCALSTACK_AUTH_TOKEN=

# HTTP Server
HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=30s
HTTP_SHUTDOWN_TIMEOUT=15s

# Logging
LOG_LEVEL=info

# PostgreSQL
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/processing_db?sslmode=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONN_LIFETIME=30m
POSTGRES_HEALTHCHECK_PERIOD=30s

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE_VIDEO_PROCESS=video.process
RABBITMQ_QUEUE_STATUS_UPDATE=status.update
RABBITMQ_QUEUE_VIDEO_COMPLETED=video.completed
RABBITMQ_QUEUE_VIDEO_FAILED=video.failed
RABBITMQ_CONSUMER_TAG=processing-service-consumer
RABBITMQ_PREFETCH_COUNT=1

# AWS S3
S3_REGION=us-east-1
S3_INPUT_BUCKET=videos
S3_OUTPUT_BUCKET=frames
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_USE_PATH_STYLE=false

# Worker
WORKER_CONCURRENCY=1
WORKER_FFMPEG_BIN=ffmpeg
